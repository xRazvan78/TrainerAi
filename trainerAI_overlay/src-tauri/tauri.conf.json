{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "trainerai",
  "version": "0.1.0",
  "identifier": "com.gmirc.trainerai",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "dx serve --port 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "dx build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TrainerAI Overlay",
        "width": 1920,
        "height": 1080,
        "x": 0,
        "y": 0,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "visible": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}